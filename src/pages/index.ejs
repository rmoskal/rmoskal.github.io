<script>

    document.querySelectorAll('.arrow').forEach(each => each.addEventListener('click',e=>{
        console.log(  e.target.firstElementChild)
        e.target.firstElementChild.classList.toggle("truncate")
    
    }))

    document.body.onload = function() {
        const params = new URLSearchParams(window.location.search);
        let items = params.get("items");
        if (!items)
            return 

           
        items.split(',').map(o=>`c${o}`).forEach(
            o=>{
                el = document.getElementById(o)
                if (!el) return;
                const bodyDiv = el.querySelector('.truncate');
                if (bodyDiv) bodyDiv.classList.remove("truncate");
                el.style.border = 'dashed';
                el.style.borderWidth = '2px';
            }
        )

}

    
    </script>